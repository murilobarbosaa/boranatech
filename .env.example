# Servidor
PORT=3000
NODE_ENV=development
APP_PUBLIC_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:5173

# Frontend (público no bundle Vite)
# Estas chaves VITE_ podem ser expostas no navegador.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_AUTH_REDIRECT_PATH=/perfil
VITE_AUTH_GOOGLE_ENABLED=true
# Domínio canônico de produção (sem barra final). Fixa o redirect do OAuth para
# sempre voltar a este host. Em preview/local deixe vazio: usa a origin atual do
# navegador. Produção (Vercel): https://boranatech.com.br
VITE_SITE_URL=

# Login social via Supabase Auth
# Fluxo atual: SPA/client-side com detectSessionInUrl=true.
# O Supabase redireciona de volta para /perfil e o client detecta a sessão na URL.
#
# Supabase Dashboard > Authentication > URL Configuration
# Site URL:
# - https://boranatech.com.br
# Additional Redirect URLs:
# - http://localhost:3000/perfil
# - http://localhost:5173/perfil
# - https://boranatech.com.br/perfil
#
# Supabase Dashboard > Authentication > Sign In / Providers
# Ative Google e preencha Client ID / Client Secret vindos do Google Cloud.
#
# Google Cloud OAuth
# Authorized JavaScript origins:
# - http://localhost:3000
# - http://localhost:5173
# - https://boranatech.com.br
# Authorized redirect URI:
# - https://vlcvaanlkqyxemrxsxzn.supabase.co/auth/v1/callback

# IA
OPENAI_API_KEY=

# GitHub (analisador de portfolio)
# Opcional. Sem token: 60 req/h por IP. Com token: 5000 req/h.
# Use um token read-only, basta acesso a repos publicos.
GITHUB_TOKEN=

# Supabase - lado servidor (secreto; nunca usar prefixo VITE_)
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Somente backend/servidor. Nunca colocar como VITE_SUPABASE_SERVICE_ROLE_KEY.
SUPABASE_SERVICE_ROLE_KEY=

# Pagamento
# Seletor do provider dos fluxos de saida (checkout/cancel/reactivate).
# "stripe" (default) ou "asaas". Os webhooks tem rota fixa por provider e nao
# dependem deste seletor. Valor invalido aborta o boot (fail-closed).
PAYMENT_PROVIDER=stripe

# Asaas (legado: mantido para as assinaturas existentes, sem novos checkouts)
ASAAS_API_KEY=
# Gerado no painel do Asaas (botao "Gerar token"). Deve bater com o token configurado la.
ASAAS_WEBHOOK_TOKEN=
ASAAS_ENV=sandbox

# Stripe (secretos; SO no backend, nunca com prefixo VITE_)
STRIPE_SECRET_KEY=
# Signing secret do endpoint de webhook (whsec_...). No `stripe listen` local ele
# e impresso no terminal; em producao vem do painel (Developers > Webhooks).
STRIPE_WEBHOOK_SECRET=
# price_ids gerados por `pnpm exec tsx scripts/stripe-setup.mjs`. Sandbox e
# producao tem price_ids DIFERENTES; rode o script uma vez por ambiente.
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_SEMIANNUAL=
STRIPE_PRICE_PRO_ANNUAL=

# PostHog. ATENCAO: as chaves de server e client sao credenciais DIFERENTES.
# Server (Railway): leitura de analytics no admin via HogQL.
# POSTHOG_API_KEY e a Personal API Key (phx_...), leitura, com escopo de /query/.
POSTHOG_API_KEY=
# Id numerico do projeto no PostHog (Project settings).
POSTHOG_PROJECT_ID=
# Regiao/host da API. US: https://us.posthog.com  UE: https://eu.posthog.com
POSTHOG_HOST=https://us.posthog.com
# Client (Vercel): captura no navegador (posthog-js).
# VITE_POSTHOG_KEY e a chave PUBLICA de projeto (phc_...), captura, exposta ao browser.
VITE_POSTHOG_KEY=
# Host de captura (mesma regiao do projeto). US: https://us.i.posthog.com
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Integrações externas (opcionais)
CURRENTS_API_KEY=
JOOBLE_API_KEY=
SYMPLA_API_KEY=

# Vagas multi-fonte (opcionais; vazias desligam a fonte no sync)
# Adzuna: app gratuito em https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
# Token dedicado para ler os repos de vagas do GitHub. Opcional: sem ele o
# sync reusa o GITHUB_TOKEN acima; sem nenhum, roda em modo reduzido.
GITHUB_VAGAS_TOKEN=

# Voz do Natechinho nas entrevistas (ElevenLabs, opcional)
# Vazios desligam a feature: a rota de fala responde 503 tts_unavailable.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# Default: eleven_multilingual_v2
ELEVENLABS_MODEL_ID=
# Teto diario de geracoes de fala por usuario Pro (default 200)
INTERVIEW_TTS_DAILY_LIMIT_PRO=

# Capas de filmes e séries da seção Dicas (build-time, opcional).
# Sem ela, o build segue normal e a seção usa o fallback colorido.
# Rode: pnpm posters (grava o posterPath em client/src/lib/dicasPosters.generated.ts)
TMDB_API_KEY=

# Limites de IA - será usado no Prompt 4
AI_DAILY_LIMIT_FREE=5
AI_DAILY_LIMIT_PRO=50

# Moderação de avatar
# Numero de denunciantes distintos que escondem a foto automaticamente (pending_review).
# Ausente ou invalido cai no default 3.
AVATAR_REPORT_HIDE_THRESHOLD=3
# Score (0..1) a partir do qual a moderacao OpenAI bloqueia a imagem do avatar.
# Ausente ou invalido cai no default 0.5.
AVATAR_MODERATION_SCORE_THRESHOLD=0.5

# Cron
CRON_SECRET=

# Lista de espera / portao de lancamento
# WAITLIST_MODE: "gated" (default) mantem o portao fechado; "open" libera geral.
WAITLIST_MODE=gated
# Codigo de acesso beta. Se ausente, POST /api/beta/unlock sempre responde 401.
WAITLIST_ACCESS_CODE=
# Secret HMAC do token de beta. Se ausente, o portao nao emite token (sem crashar).
WAITLIST_TOKEN_SECRET=

# Dev-only: lista de user ids (uuid, separados por vírgula) que enxergam como Pro
# fora de produção, para testar features Pro localmente. Ignorada quando
# NODE_ENV=production. Somente backend/servidor; NUNCA prefixar com VITE_.
DEV_PRO_USER_IDS=

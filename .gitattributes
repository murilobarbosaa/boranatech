# Normalize all text files to LF in the repo and on checkout.
# The project is built and deployed on Linux (Railway/Vercel), so LF is canonical.
* text=auto eol=lf

# Binary assets: never normalize.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.svg   text eol=lf
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.pdf   binary
*.mp4   binary
*.webm  binary
